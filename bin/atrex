#!/usr/bin/env bash
set -euo pipefail

# ── Atrex AI CLI ──────────────────────────────────────────────────────────────
# Usage: atrex <command>
# Commands: start, stop, restart, status, logs, update, open, setup, token, uninstall, help

CONFIG_DIR="$HOME/.atrex"
CONFIG_FILE="$CONFIG_DIR/config"
PID_FILE="$CONFIG_DIR/agent.pid"
APP_NAME="atrex-ai"

# ── Colors ────────────────────────────────────────────────────────────────────
BOLD='\033[1m'
DIM='\033[2m'
RED='\033[0;31m'
GREEN='\033[0;32m'
AMBER='\033[0;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

ok()   { echo -e "  ${GREEN}✓${RESET}  $1"; }
info() { echo -e "  ${CYAN}→${RESET}  $1"; }
warn() { echo -e "  ${AMBER}!${RESET}  $1"; }
fail() { echo -e "  ${RED}✗${RESET}  $1"; exit 1; }

# ── Resolve install directory ─────────────────────────────────────────────────
INSTALL_DIR=""

# 1. From config file (written by install.sh)
if [ -f "$CONFIG_FILE" ]; then
  INSTALL_DIR=$(grep "^INSTALL_DIR=" "$CONFIG_FILE" 2>/dev/null | cut -d'=' -f2 || true)
fi

# 2. Follow the symlink back to the real script location
if [ -z "$INSTALL_DIR" ] || [ ! -d "$INSTALL_DIR" ]; then
  SCRIPT_SRC="${BASH_SOURCE[0]}"
  while [ -L "$SCRIPT_SRC" ]; do
    SCRIPT_SRC="$(readlink "$SCRIPT_SRC")"
  done
  INSTALL_DIR="$(cd "$(dirname "$SCRIPT_SRC")/.." && pwd)"
fi

if [ ! -f "$INSTALL_DIR/package.json" ]; then
  fail "Could not locate Atrex AI installation. Run the installer again."
fi

# ── PM2 detection ─────────────────────────────────────────────────────────────
HAS_PM2=false
if command -v pm2 &>/dev/null; then
  HAS_PM2=true
fi

# ── Process helpers ───────────────────────────────────────────────────────────
is_running_pm2() {
  pm2 list 2>/dev/null | grep -q "$APP_NAME" && \
  pm2 list 2>/dev/null | grep "$APP_NAME" | grep -q "online"
}

is_running_pid() {
  [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

is_running() {
  if [ "$HAS_PM2" = true ]; then
    is_running_pm2
  else
    is_running_pid
  fi
}

get_port() {
  grep "^WEB_ADMIN_PORT=" "$INSTALL_DIR/.env" 2>/dev/null | cut -d'=' -f2 || echo "3000"
}

# ── Commands ──────────────────────────────────────────────────────────────────
cmd_start() {
  if is_running; then
    warn "Atrex AI is already running. Use ${BOLD}atrex restart${RESET} to restart."
    return
  fi

  if [ ! -f "$INSTALL_DIR/dist/index.js" ]; then
    fail "Build artefacts missing — run ${BOLD}npm run build${RESET} in $INSTALL_DIR."
  fi

  info "Starting Atrex AI…"

  if [ "$HAS_PM2" = true ]; then
    cd "$INSTALL_DIR"
    if [ -f "ecosystem.config.js" ]; then
      pm2 start ecosystem.config.js --silent
    else
      pm2 start dist/index.js --name "$APP_NAME" --silent
    fi
    ok "Started with PM2"
    info "Run ${BOLD}pm2 save${RESET} to persist across reboots"
  else
    mkdir -p "$CONFIG_DIR"
    cd "$INSTALL_DIR"
    nohup node dist/index.js >> "$CONFIG_DIR/agent.log" 2>&1 &
    local NEW_PID=$!
    # Verify the process actually stayed alive — node could've crashed instantly
    sleep 0.5
    if ! kill -0 "$NEW_PID" 2>/dev/null; then
      fail "Agent failed to start — see ${BOLD}$CONFIG_DIR/agent.log${RESET}"
    fi
    echo "$NEW_PID" > "$PID_FILE"
    ok "Started (PID $NEW_PID)"
    info "Logs: $CONFIG_DIR/agent.log"
  fi

  local PORT
  PORT=$(get_port)
  info "Dashboard → http://localhost:${PORT}"
}

cmd_stop() {
  if ! is_running; then
    warn "Atrex AI is not running."
    return
  fi

  info "Stopping Atrex AI…"

  if [ "$HAS_PM2" = true ]; then
    pm2 stop "$APP_NAME" --silent
    ok "Stopped"
  else
    if [ -f "$PID_FILE" ]; then
      kill "$(cat "$PID_FILE")" 2>/dev/null || true
      rm -f "$PID_FILE"
      ok "Stopped"
    fi
  fi
}

cmd_restart() {
  info "Restarting Atrex AI…"

  if [ "$HAS_PM2" = true ]; then
    if pm2 list 2>/dev/null | grep -q "$APP_NAME"; then
      pm2 restart "$APP_NAME" --silent
    else
      cmd_start
      return
    fi
    ok "Restarted"
  else
    cmd_stop
    sleep 1
    cmd_start
  fi
}

cmd_status() {
  echo ""
  echo -e "  ${BOLD}Atrex AI${RESET}"
  echo -e "  ${DIM}Install: $INSTALL_DIR${RESET}"
  echo ""

  if is_running; then
    echo -e "  Status   ${GREEN}● online${RESET}"
  else
    echo -e "  Status   ${DIM}○ offline${RESET}"
  fi

  if [ "$HAS_PM2" = true ] && pm2 list 2>/dev/null | grep -q "$APP_NAME"; then
    echo ""
    pm2 show "$APP_NAME" 2>/dev/null | grep -E "status|uptime|memory|cpu|restarts" | \
      sed 's/^/  /' || true
  elif [ -f "$PID_FILE" ]; then
    local PID
    PID=$(cat "$PID_FILE")
    echo -e "  PID      $PID"
  fi

  local PORT
  PORT=$(get_port)
  echo -e "  Dashboard  http://localhost:${PORT}"
  echo ""
}

cmd_logs() {
  local LINES="${2:-80}"

  if [ "$HAS_PM2" = true ] && pm2 list 2>/dev/null | grep -q "$APP_NAME"; then
    pm2 logs "$APP_NAME" --lines "$LINES"
    return
  fi

  # No-PM2 install: nohup output lands in $CONFIG_DIR/agent.log; the agent itself
  # writes structured logs to $INSTALL_DIR/logs/YYYY-MM-DD.log. Prefer the
  # structured ones if they exist.
  local STRUCTURED_DIR="$INSTALL_DIR/logs"
  local LATEST=""
  if [ -d "$STRUCTURED_DIR" ]; then
    LATEST=$(ls -t "$STRUCTURED_DIR"/*.log 2>/dev/null | head -1 || true)
  fi

  if [ -z "$LATEST" ] && [ -f "$CONFIG_DIR/agent.log" ]; then
    LATEST="$CONFIG_DIR/agent.log"
  fi

  if [ -z "$LATEST" ]; then
    warn "No log files found yet — start the agent first with ${BOLD}atrex start${RESET}."
    return
  fi

  info "Tailing $LATEST"
  tail -n "$LINES" -f "$LATEST"
}

cmd_update() {
  info "Updating Atrex AI…"
  echo ""

  cd "$INSTALL_DIR"

  # .git is removed on install — fetch a fresh copy and replace dist/
  local REPO_URL="https://github.com/Jonas1220/atrex-ai.git"
  local TMP_DIR
  TMP_DIR=$(mktemp -d)

  info "Downloading latest release…"
  git clone --depth 1 "$REPO_URL" "$TMP_DIR" --quiet

  info "Installing dependencies…"
  cp "$TMP_DIR/package.json" "$TMP_DIR/package-lock.json" "$INSTALL_DIR/" 2>/dev/null || true
  npm install --silent

  info "Building…"
  cp -r "$TMP_DIR/src" "$INSTALL_DIR/"
  npm run build --silent

  # Copy updated plugins and config templates (don't overwrite live configs)
  cp -r "$TMP_DIR/plugins" "$INSTALL_DIR/"
  for src in "$TMP_DIR"/config/*.initial.md; do
    [ -f "$src" ] || continue
    cp "$src" "$INSTALL_DIR/config/"
  done

  rm -rf "$TMP_DIR"
  ok "Update complete"

  if is_running; then
    info "Restarting agent…"
    cmd_restart
  else
    info "Run ${BOLD}atrex start${RESET} to start the updated agent."
  fi
}

cmd_uninstall() {
  echo ""
  echo -e "  ${BOLD}${RED}Uninstall Atrex AI${RESET}"
  echo ""
  echo -e "  This will permanently delete:"
  echo -e "    ${DIM}• $INSTALL_DIR${RESET}  (install directory)"
  echo -e "    ${DIM}• $CONFIG_DIR${RESET}  (CLI config)"
  echo -e "    ${DIM}• atrex CLI command${RESET}"
  echo ""
  echo -n "  Are you sure? [y/N] "
  read -r CONFIRM
  if [[ ! "$CONFIRM" =~ ^[Yy]$ ]]; then
    echo "  Aborted."
    exit 0
  fi
  echo ""

  # Stop and remove from PM2
  if [ "$HAS_PM2" = true ] && pm2 list 2>/dev/null | grep -q "$APP_NAME"; then
    info "Stopping and removing from PM2…"
    pm2 delete "$APP_NAME" --silent 2>/dev/null || true
    pm2 save --force --silent 2>/dev/null || true
    ok "Removed from PM2"
  elif is_running_pid; then
    info "Stopping agent…"
    kill "$(cat "$PID_FILE")" 2>/dev/null || true
    ok "Stopped"
  fi

  # Remove CLI symlink
  info "Removing atrex CLI…"
  npm unlink --global atrex 2>/dev/null || \
    npm rm --global atrex 2>/dev/null || \
    sudo npm unlink --global atrex 2>/dev/null || true
  ok "CLI removed"

  # Remove install directory
  info "Removing install directory…"
  rm -rf "$INSTALL_DIR"
  ok "Removed $INSTALL_DIR"

  # Remove CLI config
  rm -rf "$CONFIG_DIR"
  ok "Removed $CONFIG_DIR"

  echo ""
  echo -e "  ${GREEN}${BOLD}Atrex AI uninstalled.${RESET}"
  echo ""
}

cmd_open() {
  local PORT
  PORT=$(get_port)
  local URL="http://localhost:${PORT}"
  info "Opening $URL"

  if command -v xdg-open &>/dev/null; then
    xdg-open "$URL"
  elif command -v open &>/dev/null; then
    open "$URL"
  else
    info "Visit: $URL"
  fi
}

cmd_setup() {
  cd "$INSTALL_DIR"

  if [ ! -f "dist/setup-cli.js" ]; then
    fail "Setup script missing — run 'npm run build' in $INSTALL_DIR first."
  fi

  local WAS_RUNNING=false
  if is_running; then
    WAS_RUNNING=true
    info "Stopping agent for setup…"
    cmd_stop
  fi

  echo ""
  node dist/setup-cli.js
  local SETUP_RC=$?
  if [ "$SETUP_RC" -ne 0 ]; then
    if [ "$WAS_RUNNING" = true ]; then
      info "Restarting agent…"
      cmd_start
    fi
    exit "$SETUP_RC"
  fi

  if [ "$WAS_RUNNING" = true ]; then
    info "Restarting agent with new config…"
    cmd_start
    return
  fi

  echo -n "  Start the agent now? [Y/n] "
  read -r ANS
  if [[ ! "$ANS" =~ ^[Nn]$ ]]; then
    cmd_start
  else
    info "Run ${BOLD}atrex start${RESET} when ready."
  fi
}

cmd_token() {
  local ENV_FILE="$INSTALL_DIR/.env"
  if [ ! -f "$ENV_FILE" ]; then
    fail ".env not found. Start the agent once to generate a token."
  fi
  local TOKEN
  TOKEN=$(grep "^WEB_ADMIN_TOKEN=" "$ENV_FILE" 2>/dev/null | cut -d'=' -f2 || true)
  if [ -z "$TOKEN" ]; then
    warn "No admin token found. Start the agent first — it will be generated automatically."
    return
  fi
  echo ""
  echo -e "  ${BOLD}Admin Token${RESET}"
  echo -e "  ${CYAN}${TOKEN}${RESET}"
  echo ""
  echo -e "  ${DIM}Use this to authenticate with the web dashboard.${RESET}"
  echo ""
}

cmd_help() {
  echo ""
  echo -e "  ${BOLD}${AMBER}atrex${RESET} — Atrex AI CLI"
  echo ""
  echo -e "  ${BOLD}Usage:${RESET} atrex <command>"
  echo ""
  echo -e "  ${BOLD}Commands:${RESET}"
  echo -e "    ${AMBER}start${RESET}      Start the agent in the background"
  echo -e "    ${AMBER}stop${RESET}       Stop the agent"
  echo -e "    ${AMBER}restart${RESET}    Restart the agent"
  echo -e "    ${AMBER}status${RESET}     Show running status and uptime"
  echo -e "    ${AMBER}logs${RESET}       Tail live log output"
  echo -e "    ${AMBER}update${RESET}     Pull latest code and restart"
  echo -e "    ${AMBER}open${RESET}       Open the web dashboard in your browser"
  echo -e "    ${AMBER}setup${RESET}      Run the terminal onboarding wizard (Telegram + AI provider)"
  echo -e "    ${AMBER}token${RESET}      Show the web dashboard admin token"
  echo -e "    ${AMBER}uninstall${RESET}  Remove Atrex AI and all its files"
  echo -e "    ${AMBER}help${RESET}       Show this message"
  echo ""
  echo -e "  ${DIM}Install dir: $INSTALL_DIR${RESET}"
  echo ""
}

# ── Router ────────────────────────────────────────────────────────────────────
COMMAND="${1:-help}"

case "$COMMAND" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  logs)    cmd_logs "$@" ;;
  update)  cmd_update ;;
  open)    cmd_open ;;
  setup)   cmd_setup ;;
  token)     cmd_token ;;
  uninstall) cmd_uninstall ;;
  help|--help|-h) cmd_help ;;
  *)
    echo -e "  ${RED}Unknown command:${RESET} $COMMAND"
    cmd_help
    exit 1
    ;;
esac
