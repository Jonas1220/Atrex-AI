TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=
# Comma-separated Telegram user IDs — only these users can talk to the agent
# Leave empty to allow anyone (not recommended)
# Get your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# Web admin panel (runs on localhost only)
# Port is set automatically during installation (random for security)
# Override here if needed — leave blank to use the installed default
WEB_ADMIN_PORT=
# Optional bearer token to protect the admin panel
# If set, the browser will prompt for it on first visit
WEB_ADMIN_TOKEN=
