# ── Required ──────────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs — only these users can talk to the agent.
# Leave empty to allow anyone (not recommended). Get your ID from @userinfobot.
ALLOWED_USER_IDS=

# ── AI Provider (set ONE of these — selected via config/settings.json) ────────
# Anthropic — get a key at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Moonshot (Kimi) — get a key at platform.kimi.ai → API Keys
MOONSHOT_API_KEY=

# Ollama (local install) — URL of your Ollama server, no API key needed
OLLAMA_BASE_URL=

# OpenAI uses OAuth (ChatGPT account login) — no key here.
# Connect from the dashboard Settings page after setup.

# ── Web admin panel ───────────────────────────────────────────────────────────
# Port for the dashboard (set automatically during install — random for security).
WEB_ADMIN_PORT=
# Auto-generated on first run if not set. Run `atrex token` to retrieve it.
WEB_ADMIN_TOKEN=
